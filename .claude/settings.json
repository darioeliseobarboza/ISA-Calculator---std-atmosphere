{
  "preferredNotifChannel": "terminal_bell",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "additionalDirectories": [
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-pre-compact.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-session-resume.sh"
          }
        ]
      }
    ]
  }
}
