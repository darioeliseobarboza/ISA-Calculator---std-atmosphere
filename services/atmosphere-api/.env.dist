# atmosphere-api — environment variables
# Copy to .env for local development (.env is git-ignored). All values shown are
# safe placeholders / defaults; loadConfig (cmd/atmosphere-api/config.go) reads them.

# Runtime environment: "development" | "production".
# In production, CORS_ALLOWED_ORIGINS is required (fail-fast).
ENV=development

# Address the HTTP server listens on (host:port; ":8080" binds all interfaces).
HTTP_ADDR=:8080

# Directory where structured log files (slogx) are written.
LOG_DIR=./logs

# Enable debug-level logging ("true" | "false").
LOG_DEBUG=false

# Comma-separated list of origins allowed for CORS (no wildcard).
# Required in production. Example:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:8081
